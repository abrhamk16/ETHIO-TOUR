            <div class="card"><img src="https://images.pexels.com/photos/271168/pexels-photo-271168.jpeg?auto=compress&cs=tinysrgb&w=400"><div class="card-body"><h3>Hyatt Regency</h3><p>Modern comfort on Meskel Square.</p><button class="btn btn-book">BOOK NOW</button></div></div>
            <div class="card"><img src="https://images.pexels.com/photos/164595/pexels-photo-164595.jpeg?auto=compress&cs=tinysrgb&w=400"><div class="card-body"><h3>Hilton Addis</h3><p>Legendary service and thermal pools.</p><button class="btn btn-book">BOOK NOW</button></div></div>
            <div class="card"><img src="https://images.pexels.com/photos/261169/pexels-photo-261169.jpeg?auto=compress&cs=tinysrgb&w=400"><div class="card-body"><h3>Radisson Blu</h3><p>Premium business and leisure stay.</p><button class="btn btn-book">BOOK NOW</button></div></div>
            <div class="card"><img src="https://images.pexels.com/photos/258154/pexels-photo-258154.jpeg?auto=compress&cs=tinysrgb&w=400"><div class="card-body"><h3>Kuriftu Resort</h3><p>Bishoftu's paradise escape.</p><button class="btn btn-book">BOOK NOW</button></div></div>
            <div class="card"><img src="https://images.pexels.com/photos/271618/pexels-photo-271618.jpeg?auto=compress&cs=tinysrgb&w=400"><div class="card-body"><h3>Golden Tulip</h3><p>European elegance in Bole.</p><button class="btn btn-book">BOOK NOW</button></div></div>
            <div class="card"><img src="https://images.pexels.com/photos/2034335/pexels-photo-2034335.jpeg?auto=compress&cs=tinysrgb&w=400"><div class="card-body"><h3>Haile Resort</h3><p>Luxury stay by Lake Awassa.</p><button class="btn btn-book">BOOK NOW</button></div></div>
            <div class="card"><img src="https://images.pexels.com/photos/271619/pexels-photo-271619.jpeg?auto=compress&cs=tinysrgb&w=400"><div class="card-body"><h3>Elilly Hotel</h3><p>Modern luxury in Kasanchis.</p><button class="btn btn-book">BOOK NOW</button></div></div>
            <div class="card"><img src="https://images.pexels.com/photos/1838554/pexels-photo-1838554.jpeg?auto=compress&cs=tinysrgb&w=400"><div class="card-body"><h3>Marriott Executive</h3><p>Long-stay high-end suites.</p><button class="btn btn-book">BOOK NOW</button></div></div>
        </div>
    </section>

    <section id="map">
        <div class="section-title"><h2>Explore Ethiopia 3D Map</h2><div class="underline"></div></div>
        <div id="map-container"></div>
    </section>

    <section id="event">
        <div class="section-title"><h2>Celebrities & Culture</h2><div class="underline"></div></div>
        <div class="grid">
            <div class="card"><img src="https://images.pexels.com/photos/15857467/pexels-photo-15857467.jpeg?auto=compress&cs=tinysrgb&w=400"><div class="card-body"><h3>Coffee Ceremony</h3><p>The cultural heart of Ethiopian social life.</p></div></div>
            <div class="card"><img src="https://images.pexels.com/photos/2539394/pexels-photo-2539394.jpeg?auto=compress&cs=tinysrgb&w=400"><div class="card-body"><h3>Meskel Festival</h3><p>The finding of the true cross bonfire.</p></div></div>
            <div class="card"><img src="https://images.pexels.com/photos/4356144/pexels-photo-4356144.jpeg?auto=compress&cs=tinysrgb&w=400"><div class="card-body"><h3>Modern Music</h3><p>Home of the legendary Ethio-Jazz.</p></div></div>
        </div>
    </section>

    <section id="contact">
        <div class="section-title"><h2>Contact Professional Support</h2><div class="underline"></div></div>
        <div class="contact-container">
            <div class="contact-info">
                <h3>ETHIO TOUR HQ</h3>
                <p><i class="fas fa-map-marker-alt"></i> Bole Road, Addis Ababa, Ethiopia</p>
                <p><i class="fas fa-phone"></i> +251 911 223 344</p>
                <p><i class="fas fa-envelope"></i> contact@ethiotour.et</p>
                <div class="socials" style="justify-content: flex-start; margin-top: 20px;">
                    <i class="fab fa-facebook"></i> <i class="fab fa-instagram"></i> <i class="fab fa-twitter"></i>
                </div>
            </div>
            <form onsubmit="event.preventDefault(); alert('Request Sent!')">
                <div class="form-group"><input type="text" placeholder="Full Name" required></div>
                <div class="form-group"><input type="email" placeholder="Email Address" required></div>
                <div class="form-group"><textarea rows="4" placeholder="How can we help your journey?" required></textarea></div>
                <button type="submit" class="btn btn-book">SEND INQUIRY</button>
            </form>
        </div>
    </section>

    <div id="loginModal" class="modal">
        <div class="modal-content">
            <div class="tabs">
                <div class="tab active" onclick="alert('Login View')">LOGIN</div>
                <div class="tab" onclick="alert('Signup View')">SIGN UP</div>
            </div>
            <div class="form-group"><input type="text" placeholder="Username / Email"></div>
            <div class="form-group"><input type="password" placeholder="Password"></div>
            <button class="btn btn-book" onclick="toggleModal('loginModal')">ENTER</button>
            <p onclick="toggleModal('loginModal')" style="cursor:pointer; text-align:center; margin-top:15px; font-weight:700;">CLOSE</p>
        </div>
    </div>

    <footer>
        <div class="socials"><i class="fab fa-facebook"></i><i class="fab fa-instagram"></i><i class="fab fa-youtube"></i></div>
        <p>&copy; 2026 ETHIO TOUR | The Land of Origin</p>
    </footer>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        // Real Map Initialization
        const map = L.map('map-container').setView([9.145, 40.4896], 6);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
        L.marker([9.03, 38.74]).addTo(map).bindPopup('<b>Addis Ababa</b><br>Capital City').openPopup();

        // Theme Toggle Logic
        function toggleTheme() {
            const body = document.documentElement;
            const current = body.getAttribute('data-theme');
            body.setAttribute('data-theme', current === 'dark' ? 'light' : 'dark');
            const icon = document.querySelector('.icon-btn i');
            icon.className = current === 'dark' ? 'fas fa-moon' : 'fas fa-sun';
        }

        // Scroll Logic
        window.onscroll = function() {
            let s = document.getElementById("scrollTop");
            if (document.body.scrollTop > 500 || document.documentElement.scrollTop > 500) {
                s.style.display = "flex";
            } else { s.style.display = "none"; }
        };

        function toggleModal(id) {
            const m = document.getElementById(id);
            m.style.display = (m.style.display === 'flex') ? 'none' : 'flex';
        }
    </script>
</body>
</html>